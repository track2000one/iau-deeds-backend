generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AttachmentEntityType {
  deed
  allocated_land
  delivered_land
  leased_land_out
  leased_land_in
  leased_building_out
  leased_building_in
}

enum AttachmentType {
  deed_image
  plan_image
  location_image
  contract_image
  delivery_minutes
  other
}

enum AppUserRole {
  admin
  employee
}

model AppUser {
  id           String      @id @default(cuid())
  username     String
  email        String      @unique
  passwordHash String
  role         AppUserRole @default(employee)
  isActive     Boolean     @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([role])
  @@index([isActive])
}

model Deed {
  id                  String    @id @default(cuid())
  propertyDescription String
  usageType           String
  deedNumber          String    @unique
  deedDate            DateTime?
  plotNumber          String?
  planNumber          String?
  area                Float     @default(0)
  location            String?
  coordinates         String?
  isPlanned           Boolean   @default(false)
  city                String?
  district            String?
  region              String?
  notes               String?
  createdBy           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model AllocatedLand {
  id                  String   @id @default(cuid())
  propertyDescription String
  plotNumber          String?
  planNumber          String?
  area                Float    @default(0)
  usageType           String?
  region              String?
  city                String?
  district            String?
  coordinates         String?
  googleEarthLink     String?
  notes               String?
  createdBy           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model DeliveredLand {
  id                    String    @id @default(cuid())
  recipientEntity       String
  deliveryDate          DateTime?
  propertyDescription   String
  plotNumber            String?
  planNumber            String?
  area                  Float     @default(0)
  location              String?
  coordinates           String?
  deliveryMinutesNumber String?
  notes                 String?
  createdBy             String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model LeasedLandOut {
  id                String    @id @default(cuid())
  tenant            Json
  contractNumber    String
  contractStartDate DateTime?
  contractDuration  String?
  plotNumber        String?
  planNumber        String?
  area              Float     @default(0)
  location          String?
  coordinates       String?
  rentAmount        Float?
  notes             String?
  createdBy         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model LeasedLandIn {
  id                  String   @id @default(cuid())
  owner               Json
  contractNumber      String
  contractDuration    String?
  propertyDescription String
  area                Float    @default(0)
  location            String?
  coordinates         String?
  rentAmount          Float?
  notes               String?
  createdBy           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model LeasedBuildingOut {
  id             String   @id @default(cuid())
  tenant         Json
  contractNumber String
  buildingNumber String
  planNumber     String?
  locationName   String
  area           Float    @default(0)
  city           String?
  district       String?
  coordinates    String?
  rentAmount     Float?
  notes          String?
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model LeasedBuildingIn {
  id             String   @id @default(cuid())
  owner          Json
  contractNumber String
  buildingNumber String
  locationName   String
  area           Float    @default(0)
  region         String?
  city           String?
  coordinates    String?
  rentAmount     Float?
  notes          String?
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Attachment {
  id             String               @id @default(cuid())
  entityType     AttachmentEntityType
  entityId       String
  attachmentType AttachmentType       @default(other)
  title          String
  driveUrl       String
  driveFileId    String?
  mimeType       String?
  notes          String?
  createdBy      String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([entityType, entityId])
}

model ArchiveDocument {
  id                String   @id @default(cuid())
  title             String
  category          String   @default("عام")
  documentNumber    String?
  documentDate      String?
  documentDateType  String   @default("gregorian")
  issuingAuthority  String?
  confidentiality   String   @default("internal")
  tags              String?
  description       String?
  fileName          String
  originalName      String?
  mimeType          String?
  fileSize          Float    @default(0)
  driveUrl          String
  driveFileId       String?
  createdBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([category])
  @@index([documentNumber])
  @@index([confidentiality])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  userId    String?
  details   Json?
  createdAt DateTime @default(now())
}
